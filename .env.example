# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
BETTER_AUTH_URL="http://localhost:3000"

# Secret used by Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-better-auth-secret-here"

# Drizzle / PostgreSQL
DATABASE_URL='postgresql://user:password@host:5432/dbname?sslmode=require'

# Corsair Key Encryption Key — generate with: openssl rand -hex 32
CORSAIR_KEK="your-corsair-kek-here"

# MiMo AI API Key
MIMO_API_KEY="your-mimo-api-key-here"

# GitHub OAuth (create at https://github.com/settings/developers)
BETTER_AUTH_GITHUB_CLIENT_ID="your-github-client-id"
BETTER_AUTH_GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"